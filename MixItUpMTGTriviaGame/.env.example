# Port the local web server listens on. OBS Browser Source points at this.
PORT=8765

# Port for the question editor (editor.bat). Bound to localhost only.
EDITOR_PORT=8766

# When true, editor.bat opens your browser to the editor automatically.
OPEN_BROWSER=true

# Seconds viewers have to vote on each question.
ASK_SECONDS=30

# Seconds the correct answer is displayed before the next question starts.
REVEAL_SECONDS=8

# Path to the questions JSON file. Defaults to ./questions.json next to the script.
# QUESTIONS_FILE=C:\Path\To\Your\questions.json

# Comma-separated list of Twitch usernames whose votes should be ignored.
# Defaults to: nightbot,streamelements,streamlabs,moobot
# BOT_USERNAMES=nightbot,streamelements,streamlabs,moobot

# If set, the /skip and /reset endpoints require this value in an
# X-Skip-Secret header. Leave blank to allow them without authentication.
# SKIP_SECRET=

# Scoreboard
SHOW_SCOREBOARD=true
# How many top players to list in each section (This Session / All-Time).
SCOREBOARD_SIZE=5
# The leaderboard shows one board at a time and rotates between This Session
# and All-Time this often (seconds).
SCOREBOARD_ROTATE_SECONDS=6
# Where the all-time leaderboard is stored. Delete this file to wipe all-time
# standings. Defaults to ./scores.json next to the script.
# SCORES_FILE=C:\Path\To\Your\scores.json
# Points awarded for a correct answer, by question difficulty.
POINTS_EASY=1
POINTS_MEDIUM=2
POINTS_DIFFICULT=3

# Set to true to print per-step timing to stderr.
DEBUG_TIMING=false
