# Optional: override the directory where card images and the pointer file
# are written. Defaults to this script's directory.
# IMAGE_OUTPUT_DIR=C:\Path\To\card_images

# Optional: how many recent card-*.jpg files to retain. Older ones are pruned
# at the start of each run. Default 5, minimum 1.
# KEEP_IMAGES=5

# Set to true to print per-step timing to stderr (for performance debugging).
DEBUG_TIMING=false
